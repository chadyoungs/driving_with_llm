    <header date="2026-03-09" north="0.0" south="-40.0" east="40.0" west="-40.0" vendor="CustomScenario"/>
    
    <!-- 道路定义：共4条道路（北进、南进、东进、西进） -->
    <road name="road_north" id="1" length="40.0" junction="1">
        <link>
            <predecessor elementType="junction" elementId="1"/>
            <successor elementType="road" elementId="3"/>
        </link>
        <type s="0.0" type="town"/>
        <planView>
            <geometry s="0.0" x="0.0" y="20.0" hdg="3.1415926535" length="40.0">
                <line/>
            </geometry>
        </planView>
        <lanes>
            <laneOffset s="0.0" a="0.0" b="0.0" c="0.0" d="0.0"/>
            <lanesOffset s="0.0" a="0.0"/>
            <laneSection s="0.0">
                <left>
