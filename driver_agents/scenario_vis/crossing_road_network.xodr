    <!-- 十字路口交汇定义 -->
    <junction name="crossing_junction" id="1">
        <connection id="1" incomingRoad="2" connectingRoad="1">
            <laneLink from="-1" to="-1"/>
            <laneLink from="1" to="1"/>
        </connection>
        <connection id="2" incomingRoad="4" connectingRoad="3">
            <laneLink from="-1" to="-1"/>
            <laneLink from="1" to="1"/>
        </connection>
        <connection id="3" incomingRoad="1" connectingRoad="3">
